<RootWidget>:
    orientation: "vertical"
    HeaderBar:
        size_hint_y: None
        height: "50dp"
        MDIconButton:
            icon: "menu"
            on_press: app.root.toggle_nav_drawer()
        MDLabel:
            text: "e-Jiro"
            halign: "left"
            font_style: "H5"
            text_color: 1, 1, 1, 1
    MDNavigationLayout:
        ScreenManager:
            id: screen_manager
            DashboardScreen:
            ClientsScreen:
            InventoryScreen:
            LoanScreen:
            PaymentScreen:
        MDNavigationDrawer:
            id: nav_drawer
            BoxLayout:
                orientation: "vertical"
                padding: "16dp"
                spacing: "16dp"
                MDLabel:
                    text: "Menu"
                    font_style: "H5"
                    size_hint_y: None
                    height: "40dp"
                MDFlatButton:
                    text: "Tableau de Bord"
                    on_press: app.root.ids.screen_manager.current = "dashboard"; app.root.ids.nav_drawer.set_state("close")
                MDFlatButton:
                    text: "Clients"
                    on_press: app.root.ids.screen_manager.current = "clients"; app.root.ids.nav_drawer.set_state("close")
                MDFlatButton:
                    text: "Lampes"
                    on_press: app.root.ids.screen_manager.current = "inventory"; app.root.ids.nav_drawer.set_state("close")
                MDFlatButton:
                    text: "Prêts"
                    on_press: app.root.ids.screen_manager.current = "loan"; app.root.ids.nav_drawer.set_state("close")
                MDFlatButton:
                    text: "Paiements"
                    on_press: app.root.ids.screen_manager.current = "payment"; app.root.ids.nav_drawer.set_state("close")
                Widget:
                MDFlatButton:
                    text: "Quitter"
                    on_press: root.exit_app()

<HeaderBar>:
    orientation: "horizontal"
    padding: "8dp"
    spacing: "8dp"
    canvas.before:
        Color:
            rgba: 0.2, 0.2, 0.2, 1
        Rectangle:
            pos: self.pos
            size: self.size

<MDButton>:
    size_hint_y: None
    height: "48dp"
    font_size: "16sp"

<ClientListItem>:
    size_hint_y: None
    height: "60dp"
    padding: 0, 0
    canvas.before:
        Color:
            rgba: 0.9, 0.9, 0.9, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.7, 0.7, 0.7, 1
        Line:
            points: self.x, self.y, self.x + self.width, self.y
    BoxLayout:
        orientation: "horizontal"
        size_hint_x: 1
        MDLabel:
            text: root.client_name
            size_hint_x: 0.3
            halign: "center"
            shorten: True
            shorten_from: "right"
            font_size: "16sp"
        MDLabel:
            text: root.client_telephone
            size_hint_x: 0.3
            halign: "center"
            font_size: "16sp"
        MDLabel:
            text: root.client_adresse
            size_hint_x: 0.4
            halign: "center"
            font_size: "16sp"
            shorten: True
            shorten_from: "right"

<DashboardScreen>:
    name: "dashboard"
    BoxLayout:
        orientation: "vertical"
        padding: "16dp", "8dp"
        spacing: "8dp"
        MDLabel:
            id: daily_label
            text: "Journalier: 0.00 CFA"
            halign: "center"
            font_style: "H4"
            size_hint_y: None
            height: "60dp"
        MDLabel:
            id: weekly_label
            text: "Hebdomadaire: 0.00 CFA"
            halign: "center"
            font_style: "H5"
            size_hint_y: None
            height: "40dp"
        GridLayout:
            cols: 2
            spacing: "12dp"
            size_hint_y: None
            height: "180dp"
            MDFlatButton:
                text: "Clients"
                font_size: "18sp"
                on_press: app.root.ids.screen_manager.current = "clients"
            MDFlatButton:
                text: "Lamp"
                font_size: "18sp"
                on_press: app.root.ids.screen_manager.current = "inventory"
            MDFlatButton:
                text: "Prêt"
                font_size: "18sp"
                on_press: app.root.ids.screen_manager.current = "loan"
            MDFlatButton:
                text: "Paiement"
                font_size: "18sp"
                on_press: app.root.ids.screen_manager.current = "payment"
        Widget:

<ClientsScreen>:
    name: "clients"
    BoxLayout:
        orientation: "vertical"
        padding: 0
        spacing: 0
        MDLabel:
            text: "Liste des Clients"
            halign: "center"
            font_style: "H4"
            size_hint_y: None
            height: "50dp"
        GridLayout:
            cols: 3
            size_hint_y: None
            height: "45dp"
            padding: 0, 0
            canvas.before:
                Color:
                    rgba: 0.85, 0.85, 0.85, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            MDLabel:
                text: "Nom"
                bold: True
                halign: "center"
                size_hint_x: 0.3
            MDLabel:
                text: "Telephone"
                bold: True
                halign: "center"
                size_hint_x: 0.3
            MDLabel:
                text: "Adresse"
                bold: True
                halign: "center"
                size_hint_x: 0.4
        ScrollView:
            size_hint_y: 1
            GridLayout:
                id: clients_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 0
                padding: 0
        GridLayout:
            cols: 3
            spacing: "8dp"
            size_hint_y: None
            height: "60dp"
            padding: "8dp"
            MDRaisedButton:
                text: "Nouveau"
                font_size: "16sp"
                on_press: root.show_client_form("add")
            MDRaisedButton:
                text: "Modifier"
                font_size: "16sp"
                on_press: root.show_client_form("edit")
            MDRaisedButton:
                text: "Supprimer"
                font_size: "16sp"
                bg_color: 0.9, 0.3, 0.3, 1
                on_press: root.delete_client()
        MDFlatButton:
            text: "Retour au Tableau de Bord"
            on_press: app.root.ids.screen_manager.current = "dashboard"

<InventoryScreen>:
    name: "inventory"
    BoxLayout:
        orientation: "vertical"
        padding: 0
        spacing: 0
        MDLabel:
            text: "Lamp"
            halign: "center"
            font_style: "H4"
            size_hint_y: None
            height: "50dp"
        GridLayout:
            cols: 2
            size_hint_y: None
            height: "45dp"
            padding: 0, 0
            canvas.before:
                Color:
                    rgba: 0.85, 0.85, 0.85, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            MDLabel:
                text: "Numero"
                bold: True
                halign: "center"
                size_hint_x: 0.5
            MDLabel:
                text: "Etat"
                bold: True
                halign: "center"
                size_hint_x: 0.5
        ScrollView:
            size_hint_y: 1
            GridLayout:
                id: inventory_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 0
                padding: 0
        GridLayout:
            cols: 3
            spacing: "8dp"
            size_hint_y: None
            height: "60dp"
            padding: "8dp"
            MDRaisedButton:
                text: "Nouveau"
                font_size: "16sp"
                on_press: root.show_lamp_form("add")
            MDRaisedButton:
                text: "Modifier"
                font_size: "16sp"
                on_press: root.show_lamp_form("edit")
            MDRaisedButton:
                text: "Supprimer"
                font_size: "16sp"
                bg_color: 0.9, 0.3, 0.3, 1
                on_press: root.delete_lamp()
        MDFlatButton:
            text: "Retour au Tableau de Bord"
            font_size: "16sp"
            on_press: app.root.ids.screen_manager.current = "dashboard"

<LampListItem>:
    size_hint_y: None
    height: "60dp"
    padding: 0, 0
    canvas.before:
        Color:
            rgba: 0.9, 0.9, 0.9, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.7, 0.7, 0.7, 1
        Line:
            points: self.x, self.y, self.x + self.width, self.y
    BoxLayout:
        orientation: "horizontal"
        size_hint_x: 1
        MDLabel:
            text: root.lamp_numero
            size_hint_x: 0.5
            halign: "center"
            font_size: "16sp"
        MDLabel:
            text: root.lamp_etat
            size_hint_x: 0.5
            halign: "center"
            font_size: "16sp"

<LoanListItem>:
    size_hint_y: None
    height: "60dp"
    padding: 0, 0
    canvas.before:
        Color:
            rgba: 0.9, 0.9, 0.9, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.7, 0.7, 0.7, 1
        Line:
            points: self.x, self.y, self.x + self.width, self.y
    BoxLayout:
        orientation: "horizontal"
        size_hint_x: 1
        MDLabel:
            text: root.client_nom
            size_hint_x: 0.35
            halign: "center"
            font_size: "16sp"
            shorten: True
            shorten_from: "right"
        MDLabel:
            text: root.lampe_numero
            size_hint_x: 0.25
            halign: "center"
            font_size: "16sp"
        MDLabel:
            text: root.montant_journalier + " CFA"
            size_hint_x: 0.2
            halign: "center"
            font_size: "16sp"
        CheckBox:
            id: paid_checkbox
            size_hint_x: 0.2
            active: root.is_paid
            on_active: root.dispatch("on_paid_toggle", self.active)
            canvas.before:
                Color:
                    rgba: 0.3, 0.3, 0.3, 1
                Line:
                    rectangle: self.x, self.y, self.width, self.height

<TransactionListItem>:
    size_hint_y: None
    height: "60dp"
    padding: 0, 0
    canvas.before:
        Color:
            rgba: 0.9, 0.9, 0.9, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.7, 0.7, 0.7, 1
        Line:
            points: self.x, self.y, self.x + self.width, self.y
    BoxLayout:
        orientation: "horizontal"
        size_hint_x: 1
        MDLabel:
            text: root.client_nom
            size_hint_x: 0.3
            halign: "center"
            font_size: "16sp"
            shorten: True
            shorten_from: "right"
        MDLabel:
            text: root.lampe_numero
            size_hint_x: 0.3
            halign: "center"
            font_size: "16sp"
        MDLabel:
            text: root.date_paiement
            size_hint_x: 0.2
            halign: "center"
            font_size: "14sp"
        MDLabel:
            text: root.montant
            size_hint_x: 0.2
            halign: "center"
            font_size: "14sp"

<LoanScreen>:
    name: "loan"
    BoxLayout:
        orientation: "vertical"
        padding: 0
        spacing: 0
        MDLabel:
            text: "Prêts"
            halign: "center"
            font_style: "H4"
            size_hint_y: None
            height: "50dp"
        GridLayout:
            cols: 4
            size_hint_y: None
            height: "45dp"
            padding: 0, 0
            canvas.before:
                Color:
                    rgba: 0.85, 0.85, 0.85, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            MDLabel:
                text: "Client"
                bold: True
                halign: "center"
                size_hint_x: 0.3
            MDLabel:
                text: "Lampe"
                bold: True
                halign: "center"
                size_hint_x: 0.3
            MDLabel:
                text: "Date"
                bold: True
                halign: "center"
                size_hint_x: 0.2
            MDLabel:
                text: "Statut"
                bold: True
                halign: "center"
                size_hint_x: 0.2
        ScrollView:
            size_hint_y: 1
            GridLayout:
                id: loans_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 0
                padding: 0
        GridLayout:
            cols: 3
            size_hint_y: None
            height: "45dp"
            padding: "8dp"
            spacing: "8dp"
            Spinner:
                id: client_spinner
                text: "Client"
                size_hint_x: 0.25
            Spinner:
                id: lampe_spinner
                text: "Lampe"
                size_hint_x: 0.25
            TextInput:
                id: montant_input
                hint_text: "Prix/jour"
                multiline: False
                input_filter: "float"
                size_hint_x: 0.25
                foreground_color: 0, 0, 0, 1
            MDRaisedButton:
                text: "Créer"
                size_hint_x: 0.25
                on_press: root.assign_lampe(client_spinner.text, lampe_spinner.text, montant_input.text)
        GridLayout:
            cols: 3
            spacing: "8dp"
            size_hint_y: None
            height: "60dp"
            padding: "8dp"
            MDRaisedButton:
                text: "Clore"
                font_size: "16sp"
                on_press: root.close_loan()
            MDRaisedButton:
                text: "Supprimer"
                font_size: "16sp"
                bg_color: 0.9, 0.3, 0.3, 1
                on_press: root.delete_loan()
            MDFlatButton:
                text: "Retour"
                font_size: "16sp"
                on_press: app.root.ids.screen_manager.current = "dashboard"

<PaymentScreen>:
    name: "payment"
    BoxLayout:
        orientation: "vertical"
        padding: 0
        spacing: 0
        MDLabel:
            text: "Paiements"
            halign: "center"
            font_style: "H4"
            size_hint_y: None
            height: "40dp"
        GridLayout:
            cols: 2
            size_hint_y: None
            height: "40dp"
            padding: "16dp", "4dp"
            MDLabel:
                id: daily_label
                text: "Jour: 0.00 CFA"
                halign: "center"
                font_style: "H6"
            MDLabel:
                id: weekly_label
                text: "Semaine: 0.00 CFA"
                halign: "center"
                font_style: "H6"
        GridLayout:
            cols: 4
            size_hint_y: None
            height: "45dp"
            padding: 0, 0
            canvas.before:
                Color:
                    rgba: 0.85, 0.85, 0.85, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            MDLabel:
                text: "Client"
                bold: True
                halign: "center"
                size_hint_x: 0.35
            MDLabel:
                text: "Lampe"
                bold: True
                halign: "center"
                size_hint_x: 0.25
            MDLabel:
                text: "Prix/Jour"
                bold: True
                halign: "center"
                size_hint_x: 0.2
            MDLabel:
                text: "Payé"
                bold: True
                halign: "center"
                size_hint_x: 0.2
        ScrollView:
            size_hint_y: 1
            GridLayout:
                id: loans_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: 0
                padding: 0
        BoxLayout:
            orientation: "horizontal"
            size_hint_y: None
            height: "40dp"
            padding: "8dp"
            MDRaisedButton:
                text: "Tout Marquer Payé"
                on_press: root.mark_all_paid()
        MDFlatButton:
            text: "Retour"
            font_size: "16sp"
            size_hint_y: None
            height: "48dp"
            on_press: app.root.ids.screen_manager.current = "dashboard"
</root>
